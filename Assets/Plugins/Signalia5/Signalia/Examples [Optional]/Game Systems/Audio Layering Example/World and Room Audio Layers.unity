MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 746145256}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a610e6f7d038710489f0cd6038b9b4ad, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  noteContent: "Showcase\nExplore different areas of the scene to experience how
    Audio Layering reacts dynamically:\n\nControls\nWASD / Arrow Keys \u2013 Move
    the character around the map.\n\nExterior Pond SFX \u2013 Hear ambient water
    and nature sounds.\nInterior Mute Ambience \u2013 Enter the house to silence
    environmental layers.\nInterior Store Music \u2013 Step inside the shop to switch
    to shop-specific background music.\nInterior Dark Ambience \u2013 Approach the
    cave to trigger a darker, moodier atmosphere.\n\nThis demonstrates how easily
    you can set up room-based audio and ambience transitions using Signalia\u2019s
    Audio Layering system."
