--- !u!114 &821196352
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 821196348}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a610e6f7d038710489f0cd6038b9b4ad, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  noteContent: 'Property 1 or more => Means It will play overlaid on the layer and
    track. This is best for rooms.


    Track => the name of the track in the layer.
    Think of it as "which CD the audio is on", leave it empty to use the default
    track or name it for multiple tracks.


    Note that differently named tracks
    will play on top of each other.


    Any Room Audio component should usually
    use property 1 or more, but it depends on implementation.'
